# Copy this file to `secrets.env` and fill in the values.
# secrets.env is gitignored — NEVER commit it.

# --- Translation backend: gemini (recommended) | google (free, no key) | none ---
TRANSLATE_BACKEND=gemini

# --- Google AI Studio API key (for TRANSLATE_BACKEND=gemini and the summarize bot) ---
# Get one free at https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# --- Telegram delivery (optional; without it, digests are written to out/ only) ---
# 1) Message @BotFather -> /newbot -> copy the token
# 2) Add the bot to your chat/group and send it a message
# 3) Run: python get_chat_id.py   (prints your chat id)
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
# Forum/group topic id (optional; leave empty for normal chats/DMs)
TELEGRAM_THREAD_ID=

# --- Residential proxy (optional; ONLY needed for Reddit, which blocks datacenter IPs) ---
# Format: http://user:pass@host:port
RESIDENTIAL_PROXY=
